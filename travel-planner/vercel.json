{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://wanderful-api.onrender.com/api/:path*"
    },
    {
      "source": "/health/:path*",
      "destination": "https://wanderful-api.onrender.com/health/:path*"
    }
  ]
}
